{
  "version": 2,
  "name": "familia-financas",
  "comment": "Configuração de deploy na Vercel — projeto estático puro (HTML + JS + CSS)",

  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],

  "routes": [
    {
      "comment": "SPA: todas as rotas retornam index.html (hash routing no cliente)",
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/js/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
